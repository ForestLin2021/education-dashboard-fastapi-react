# Only used by the chat feature (/api/chat) — the dashboard itself reads
# static JSON from public/data/ and does not need a backend.
# Set this to your Render backend URL after deploy, or leave it unset /
# point it at a dead URL if you don't want to run the chat backend at all.
# Example: https://epp-dashboard-backend.onrender.com
VITE_API_URL=https://your-app.onrender.com
